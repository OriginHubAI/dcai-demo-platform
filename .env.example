# Frontend
# Local single-machine default: keep these as localhost.
# If your browser is on another machine, replace the host with the server IP or hostname it can actually reach.
VITE_DATA_MODE=api
VITE_API_BASE_URL=http://localhost:18000
VITE_DATAFLOW_WEBUI_URL=http://localhost:5173
VITE_DATAFLOW_BACKEND_URL=http://localhost:8002
VITE_DFAGENT_URL=http://localhost:7860
VITE_PACKAGE_EDITOR_URL=http://localhost:18004
VITE_LLM_PROVIDER_LABEL=http://localhost:3000/v1

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:8000

# Backend PostgreSQL Database (Default to sqlite3 if empty)
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Backend downstream services
# In ASGI mode (uvicorn core.asgi:application), DataFlow-WebUI FastAPI is embedded in-process.
# Set DATAFLOW_BACKEND_URL to the same ASGI server so proxy_views loop back via ASGI dispatcher.
DATAFLOW_BACKEND_URL=http://127.0.0.1:18000
LOOPAI_BACKEND_URL=http://127.0.0.1:18003
DFAGENT_BACKEND_URL=http://127.0.0.1:7860
# Absolute path to your local DataFlow repository checkout.
DATAFLOW_REPO_ROOT=/absolute/path/to/DataFlow
# Absolute path to DataFlow operators directory
DATAFLOW_OPERATORS_ROOT=/absolute/path/to/DataFlow/dataflow/operators
CODE_SERVER_BASE_PORT=18080
PACKAGE_EDITOR_PORT=18004
# Absolute path to a writable directory used for isolated package-editor sandboxes.
PACKAGE_EDITOR_SANDBOX_ROOT=/absolute/path/to/sandboxes/package-editor
# Proxy timeout in seconds
PROXY_TIMEOUT=120

# Homepage chat provider
LLM_PROVIDER_BASE_URL=http://localhost:3000
LLM_PROVIDER_API_KEY=your-api-key
LLM_DEFAULT_MODEL=gpt-4o
LLM_AVAILABLE_MODELS=gpt-4o,deepseek-chat
LLM_REQUEST_TIMEOUT=120

# Dataflow System Integration
# Set ENABLE_MOCK_DATAFLOW to True to auto-start a mock FastAPI server for Dataflow
ENABLE_MOCK_DATAFLOW=False
DATAFLOW_MOCK_URL=http://localhost:8001
DATAFLOW_SYSTEM_URL=http://127.0.0.1:8001

# Hugging Face Datasets Integration
# HF-compatible dataset APIs are now served directly by Django at /api/hf/
# The endpoint used by the 'datasets' library to fetch data
HF_ENDPOINT=http://localhost:8000/api/hf

# Optional: Custom cache directory for HF datasets
# HF_DATASETS_CACHE=./.hf_cache

# Testing Configuration
# Virtual memory limit for running tests via run_backend_tests.sh (in GB)
TEST_MEMORY_LIMIT_GB=16
