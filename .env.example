# Dataflow System Integration
# Set ENABLE_MOCK_DATAFLOW to True to auto-start a mock FastAPI server for Dataflow
ENABLE_MOCK_DATAFLOW=False
DATAFLOW_SERVICE_URL=http://localhost:8001

# Hugging Face Datasets Integration
# Set ENABLE_MOCK_HF to True to auto-start a mock Hugging Face Hub server
# This serves sample datasets from backend/fastapi_app/sample_data/
ENABLE_MOCK_HF=False

# The URL where the mock HF server will be available (used by Django to proxy or start)
HF_SERVICE_URL=http://localhost:8002

# The endpoint used by the 'datasets' library to fetch data
# When ENABLE_MOCK_HF is True, this should point to HF_SERVICE_URL
HF_ENDPOINT=http://localhost:8002

# Optional: Custom cache directory for HF datasets
# HF_DATASETS_CACHE=./.hf_cache
